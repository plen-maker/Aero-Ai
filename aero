class AeroApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="com.aero.assistant")
        self._win = None

    def do_activate(self):
        if self._win is None:
            self._win = IslandWindow(self)
            self._win.present()
        else:
            self._win.present()
            self._win.focus()

if __name__ == "__main__":
    app = AeroApp()
    app.run(sys.argv)
