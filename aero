        self._detail_label.set_margin_top(10)
        self._detail_label.set_margin_bottom(10)
        scroll.set_child(self._detail_label)

        self._island.append(self._detail)
        self._expanded = False

    def _apply_css(self):
        p = Gtk.CssProvider()
        p.load_from_data(make_css())
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), p,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    # ── Animáció ──────────────────────────────────────────

    def _update_input_region(self, island_w):
        surf = self.get_surface()
        if surf is None:
            return
        x = (self._screen_w - island_w) // 2
        region = cairo.Region(cairo.RectangleInt(x, 0, island_w, ISLAND_H + 8))
        surf.set_input_region(region)

    def _set_width(self, w):
        self._w = w
        self.set_size_request(w, ISLAND_H)
        self._island.set_size_request(w, ISLAND_H)

    def _animate_to(self, target):
        self._target_w = target
        if self._anim:
            GLib.source_remove(self._anim)
        self._anim = GLib.timeout_add(ANIM_MS, self._anim_tick)

    def _anim_tick(self):
        diff = self._target_w - self._w
        if abs(diff) <= ANIM_STEP:
            self._set_width(self._target_w)
            self._anim = None
            return False
        self._set_width(self._w + (ANIM_STEP if diff > 0 else -ANIM_STEP))
        return True

    # ── Állapotok ─────────────────────────────────────────

    def open_input(self):
        if self._open: return
        self._open = True
        Gtk4LayerShell.set_keyboard_mode(self, Gtk4LayerShell.KeyboardMode.EXCLUSIVE)
        self._resp.set_visible(False)
        self._entry.set_visible(True)
        self._content.set_visible(True)
        self._logo.set_label("AERO")
        self._animate_to(ISLAND_W_OPEN)
        GLib.timeout_add(150, self._entry.grab_focus)

    def close_input(self):
        self._open = False
        Gtk4LayerShell.set_keyboard_mode(self, Gtk4LayerShell.KeyboardMode.NONE)
        self._stop_thinking()
        self._content.set_visible(False)
        self._logo.set_label("")
        self._detail.set_visible(False)
        self._expanded = False
        self._animate_to(ISLAND_W_IDLE)

    def _start_thinking(self):
        self._entry.set_visible(False)
        self._resp.remove_css_class("response")
        self._resp.add_css_class("thinking")
        self._resp.set_text("···")
        self._resp.set_visible(True)
        self._dots = 0
        if not self._think_tmr:
            self._think_tmr = GLib.timeout_add(350, self._tick)

    def _tick(self):
        frames = ["·  ", "·· ", "···", " ··", "  ·", " ··"]
        self._dots = (self._dots + 1) % len(frames)
        self._resp.set_text(frames[self._dots])
        return True

    def _stop_thinking(self):
        if self._think_tmr:
            GLib.source_remove(self._think_tmr)
            self._think_tmr = None

    # ── Events ────────────────────────────────────────────

    def _on_logo_click(self, gesture, n, x, y):
        if self._open:
            self.close_input()
        else:
            self.open_input()

    def _on_key(self, ctrl, keyval, *_):
        if keyval == Gdk.KEY_Escape:
            if self._awaiting_confirm:
                self._on_confirm_no()
            else:
                self.close_input()
        return False

    def _on_submit(self, entry):
        if self._awaiting_confirm:
            self._on_confirm_yes()
            return
        text = entry.get_text().strip()
        if not text: return
        entry.set_text("")
        if text.startswith("/load"):
            query = text[5:].strip()
            result = search_history(query) if query else "Használat: /load <keresett szó>"
            self._show_response(result)
            return
        entry.set_sensitive(False)
        self._last_query = text
        self._start_thinking()
        threading.Thread(target=self._ask, args=(text,), daemon=True).start()

    def _ask(self, text):
        import time
        for attempt in range(3):
            try:
                result = run_agent(text)
                break
            except Exception as e:
                msg = str(e)
                if "503" in msg and attempt < 2:
                    time.sleep(2)
                    continue
                result = "A Groq szerver túlterhelt (503), próbáld újra." if "503" in msg else f"Hiba: {e}"
                break
        if result == "__CONFIRM_EMAIL__":
            GLib.idle_add(self._confirm_email)
        else:
            GLib.idle_add(self._show_response, result)

    def _show_response(self, text):
        self._stop_thinking()
        self._full_text = text
        self._resp.remove_css_class("thinking")
        self._resp.add_css_class("response")
        self._resp.set_text(text)
        self._resp.set_visible(True)
        self._entry.set_sensitive(True)
        self._entry.set_visible(True)
        if self._last_query and not text.startswith("Nincs találat") and not text.startswith("Használat"):
            append_history(self._last_query, text)
            self._last_query = ""

    def _on_resp_click(self, gesture, n, x, y):
        if not self._full_text:
            return
        if self._expanded:
            self._detail.set_visible(False)
            self._expanded = False
            self.set_size_request(self._w, ISLAND_H)
        else:
            self._detail_label.set_text(self._full_text)
            self._detail.set_visible(True)
            self._expanded = True
            self.set_size_request(self._w, ISLAND_H + 240)

    def _confirm_email(self):
        self._stop_thinking()
        em = _pending_email
        self._entry.set_text("")
        self._entry.set_placeholder_text(f"Küldöm? → {em.get('to','?')}  [Enter=igen / Esc=nem]")
        self._entry.set_sensitive(True)
        self._entry.set_visible(True)
        self._resp.set_visible(False)
        self._awaiting_confirm = True
        GLib.timeout_add(150, self._entry.grab_focus)

    def _on_confirm_yes(self):
        self._awaiting_confirm = False
        self._entry.set_placeholder_text("Kérdezz valamit...")
        em = _pending_email.copy(); _pending_email.clear()
        self._entry.set_text("")
        self._start_thinking()
        threading.Thread(target=lambda: GLib.idle_add(
            self._show_response, _do_send_email(em["to"], em["subject"], em["body"])
        ), daemon=True).start()

    def _on_confirm_no(self):
        self._awaiting_confirm = False
        self._entry.set_placeholder_text("Kérdezz valamit...")
        _pending_email.clear()
        self._show_response("Email megszakítva.")

    # ── Diktálás ──────────────────────────────────────────────

    def _toggle_dictation(self):
        if self._recording:
            self._stop_dictation()
        else:
            self._start_dictation()

    def _start_dictation(self):
        self._recording = True
        if not self._open:
            self._open = True
            Gtk4LayerShell.set_keyboard_mode(self, Gtk4LayerShell.KeyboardMode.EXCLUSIVE)
            self._animate_to(ISLAND_W_OPEN)
        self._logo.set_visible(False)
        self._wave_area.set_visible(True)
        self._content.set_visible(False)
        self._wave_tmr = GLib.timeout_add(80, self._animate_wave)
        self._rec_file = tempfile.mktemp(suffix=".wav")
        for cmd in [
            ["pw-record", "--rate=16000", "--channels=1", self._rec_file],
            ["arecord", "-f", "S16_LE", "-r", "16000", "-c", "1", self._rec_file],
        ]:
            try:
                self._rec_proc = subprocess.Popen(cmd, stderr=subprocess.DEVNULL)
                break
            except FileNotFoundError:
                continue

    def _stop_dictation(self):
        self._recording = False
        if self._rec_proc:
            self._rec_proc.terminate()
            self._rec_proc.wait()
            self._rec_proc = None
        if self._wave_tmr:
            GLib.source_remove(self._wave_tmr)
            self._wave_tmr = None
        self._wave_area.set_visible(False)
        self._logo.set_visible(True)
        self._logo.set_label("AERO")
        self._content.set_visible(True)
        self._entry.set_sensitive(False)
        self._entry.set_placeholder_text("Átírom...")
        self._resp.set_visible(False)
        self._entry.set_visible(True)
        threading.Thread(target=self._transcribe, args=(self._rec_file,), daemon=True).start()

    def _transcribe(self, filepath):
        try:
            import time; time.sleep(0.3)
            with open(filepath, "rb") as f:
                result = groq_client.audio.transcriptions.create(
                    file=(os.path.basename(filepath), f),
                    model="whisper-large-v3-turbo",
                    language="hu",
                )
            text = result.text.strip()
        except Exception as e:
            text = ""
        finally:
            try: os.unlink(filepath)
            except: pass
        GLib.idle_add(self._set_dictated_text, text)

    def _set_dictated_text(self, text):
        self._entry.set_sensitive(True)
        self._entry.set_placeholder_text("Kérdezz valamit...")
        if text:
            self._entry.set_text(text)
            self._entry.grab_focus()
            self._entry.set_position(-1)

    def _draw_wave(self, area, cr, width, height):
        bar_w, gap = 4, 4
        n = len(self._wave_bars)
        total_w = n * bar_w + (n - 1) * gap
        x0 = (width - total_w) / 2
        r, g, b = 0.49, 0.44, 0.97  # ACCENT
        for i, h in enumerate(self._wave_bars):
            bar_h = max(4, int(h * (height - 8)))
            x = x0 + i * (bar_w + gap)
            y = (height - bar_h) / 2
            cr.set_source_rgba(r, g, b, 0.6 + h * 0.4)
            cr.rectangle(x, y, bar_w, bar_h)
            cr.fill()

    def _animate_wave(self):
        if not self._recording:
            return False
        self._wave_bars = [
            max(0.05, min(1.0, b + random.uniform(-0.35, 0.35)))
            for b in self._wave_bars
        ]
        self._wave_area.queue_draw()
        return True

    def focus(self):
        if self._open:
            self.close_input()
        else:
            self.open_input()

