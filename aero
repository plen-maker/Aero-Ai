def get_recent_emails(count: int = 3) -> str:
    if not GMAIL_USER or not GMAIL_PASS:
        return "Gmail nincs beállítva."
    try:
        mail = imaplib.IMAP4_SSL("imap.gmail.com")
        mail.login(GMAIL_USER, GMAIL_PASS)
        mail.select("INBOX")
        _, data = mail.search(None, "ALL")
        ids = data[0].split()[-count:]
        results = []
        for eid in reversed(ids):
            _, msg_data = mail.fetch(eid, "(RFC822)")
            msg = email.message_from_bytes(msg_data[0][1])
            raw = decode_header(msg["Subject"])[0]
            subject = raw[0]
            if isinstance(subject, bytes):
                subject = subject.decode(raw[1] or "utf-8", errors="replace")
            body = ""
            if msg.is_multipart():
                for part in msg.walk():
                    if part.get_content_type() == "text/plain":
                        body = part.get_payload(decode=True).decode(errors="replace")[:300]
                        break
            else:
                body = msg.get_payload(decode=True).decode(errors="replace")[:300]
            results.append(f"Feladó: {msg['From']}\nTárgy: {subject}\n{body.strip()}")
        mail.logout()
        return "\n---\n".join(results)
    except Exception as e:
        return f"Gmail hiba: {e}"

_pending_email: dict = {}

def request_send_email(to: str, subject: str, body: str) -> str:
    _pending_email.update({"to": to, "subject": subject, "body": body})
    return "__CONFIRM_EMAIL__"

def _do_send_email(to, subject, body) -> str:
    if not GMAIL_USER or not GMAIL_PASS:
        return "Gmail nincs beállítva."
    try:
        msg = MIMEText(body, "plain", "utf-8")
        msg["From"] = GMAIL_USER; msg["To"] = to; msg["Subject"] = subject
        with smtplib.SMTP_SSL("smtp.gmail.com", 465) as s:
            s.login(GMAIL_USER, GMAIL_PASS); s.send_message(msg)
        return f"Email elküldve: {to}"
    except Exception as e:
        return f"Küldési hiba: {e}"

def _load_tasks():
    if not os.path.exists(TASKS_FILE): return []
    with open(TASKS_FILE, encoding="utf-8") as f: return json.load(f)

def _save_tasks(t):
    with open(TASKS_FILE, "w", encoding="utf-8") as f: json.dump(t, f, ensure_ascii=False, indent=2)

def create_task(title: str, notes: str = "") -> str:
    t = _load_tasks()
    t.append({"id": len(t)+1, "title": title, "notes": notes,
               "created": datetime.datetime.now().isoformat(), "done": False})
    _save_tasks(t); return f"Feladat hozzáadva: {title}"

def list_tasks() -> str:
    t = _load_tasks()
    p = [x for x in t if not x.get("done")]
    return "Nincs feladat." if not p else "\n".join(
        f"[{x['id']}] {x['title']}" + (f" — {x['notes']}" if x.get("notes") else "") for x in p)

def open_url(url: str) -> str:
    if not url.startswith(("http://", "https://")):
        url = "https://" + url
    subprocess.Popen(["xdg-open", url])
    return f"Megnyitva: {url}"

def launch_app(app: str) -> str:
    try:
        subprocess.Popen([app], start_new_session=True)
        return f"Elindítva: {app}"
    except FileNotFoundError:
        # próbálj keresni más névvel
        try:
            subprocess.Popen(["bash", "-c", f"{app} &"], start_new_session=True)
            return f"Elindítva: {app}"
        except Exception as e:
            return f"Nem találom: {app} ({e})"

def run_command(command: str) -> str:
    needs_sudo = "sudo" in command or command.strip().startswith(("pacman", "yay", "paru"))
    if needs_sudo:
        # sudo kell → nyiss terminált ahol be lehet írni a jelszót
        safe = command.replace("'", "'\\''")
        launched = False
        for term in ["kitty", "alacritty", "foot", "wezterm", "xterm"]:
            try:
                subprocess.Popen([term, "-e", "bash", "-c",
                    f"{safe}; echo; echo '--- Kész, nyomj Entert ---'; read"])
                launched = True
                break
            except FileNotFoundError:
                continue
        if launched:
            return f"Terminálban futtatom (add meg a jelszót ott):\n$ {command}"
        else:
            return f"Nincs elérhető terminál. Futtasd kézzel:\n$ {command}"
    try:
        r = subprocess.run(command, shell=True, capture_output=True, text=True, timeout=20)
        out = (r.stdout + r.stderr).strip()
        return out[:800] if out else "Kész."
    except subprocess.TimeoutExpired:
        return "Időtúllépés (20s)."
    except Exception as e:
        return f"Hiba: {e}"

def complete_task(task_id: int) -> str:
    t = _load_tasks()
    for x in t:
        if x.get("id") == task_id:
            x["done"] = True; _save_tasks(t); return f"Kész: {x['title']}"
    return f"Nem találom: #{task_id}"

